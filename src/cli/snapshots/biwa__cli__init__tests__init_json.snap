---
source: src/cli/init.rs
expression: content
---
{
  "$schema": "https://biwa.takuk.me/schema/config.json",
  "clean": {
    "auto": true,
    "max_age": "30days",
    "quota_thresholds": {}
  },
  "env": {
    "forward_method": "export",
    "vars": []
  },
  "hooks": {
    "post_sync": null,
    "pre_sync": null
  },
  "ssh": {
    "host": "cse.unsw.edu.au",
    "key_path": null,
    "password": false,
    "port": 22,
    "umask": "077",
    "user": "z1234567"
  },
  "sync": {
    "auto": true,
    "engine": "sftp",
    "exclude": [
      "**/.git/**",
      "**/target/**",
      "**/node_modules/**"
    ],
    "remote_root": "~/.cache/biwa/projects",
    "sftp": {
      "max_files_to_sync": 100,
      "permissions": "recreate"
    },
    "sync_root": null
  }
}
