---
source: src/cli/init.rs
expression: content
---
# yaml-language-server: $schema=https://biwa.takuk.me/schema/config.json
# Root configuration struct for biwa.

# SSH connection configuration.
ssh:
  # Hostname or IP address of the remote host.
  #
  # Can also be specified via environment variable `BIWA_SSH_HOST`.
  #
  # Default value: cse.unsw.edu.au
  #host: cse.unsw.edu.au

  # Port to connect to on the remote host.
  #
  # Can also be specified via environment variable `BIWA_SSH_PORT`.
  #
  # Default value: 22
  #port: 22

  # Username for the SSH connection.
  #
  # Can also be specified via environment variable `BIWA_SSH_USER`.
  #
  # Default value: z1234567
  #user: z1234567

  # Optional path to the SSH private key.
  #
  # Can also be specified via environment variable `BIWA_SSH_KEY_PATH`.
  #key_path:

  # Password authentication: `false` (default), `true` (prompt), or a string value.
  #
  # Can also be specified via environment variable `BIWA_SSH_PASSWORD`.
  #
  # Default value: false
  #password: false

# Remote synchronization configuration.
sync:
  # Remote directory to sync the project to.
  #
  # Can also be specified via environment variable `BIWA_SYNC_REMOTE_ROOT`.
  #
  # Default value: ~/.cache/biwa/projects
  #remote_root: ~/.cache/biwa/projects

  # Files and directories to ignore during synchronization.
  #
  # Default value: [.git, target, node_modules]
  #ignore_files: [.git, target, node_modules]

# Environment variables configuration.
env:
  # Environment variable keys to inherit/send.
  #
  # Default value: []
  #vars: []

# Lifecycle hooks for synchronization.
hooks:
  # Command to run before synchronization.
  #pre_sync:

  # Command to run after synchronization.
  #post_sync:

# Logging configuration.
log:
  # Suppresses biwa internal logs; only remote command output is shown.
  #
  # Can also be specified via environment variable `BIWA_LOG_QUIET`.
  #
  # Default value: false
  #quiet: false

  # Suppresses all output, including remote command stdout/stderr.
  #
  # Can also be specified via environment variable `BIWA_LOG_SILENT`.
  #
  # Default value: false
  #silent: false
