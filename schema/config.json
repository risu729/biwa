{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Config",
  "type": "object",
  "properties": {
    "env": {
      "$ref": "#/$defs/EnvConfig"
    },
    "hooks": {
      "$ref": "#/$defs/HooksConfig"
    },
    "log": {
      "$ref": "#/$defs/LogConfig"
    },
    "ssh": {
      "$ref": "#/$defs/SshConfig"
    },
    "sync": {
      "$ref": "#/$defs/SyncConfig"
    }
  },
  "required": [
    "ssh",
    "sync",
    "env",
    "hooks",
    "log"
  ],
  "$defs": {
    "EnvConfig": {
      "type": "object",
      "properties": {
        "vars": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "vars"
      ]
    },
    "HooksConfig": {
      "type": "object",
      "properties": {
        "post_sync": {
          "type": [
            "string",
            "null"
          ]
        },
        "pre_sync": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "LogConfig": {
      "type": "object",
      "properties": {
        "quiet": {
          "description": "Suppresses biwa internal logs; only remote command output is shown.",
          "type": "boolean"
        },
        "silent": {
          "description": "Suppresses all output, including remote command stdout/stderr.",
          "type": "boolean"
        }
      },
      "required": [
        "quiet",
        "silent"
      ]
    },
    "PasswordConfig": {
      "description": "Password authentication configuration.\n\n- `false` (default): No password authentication.\n- `true`: Interactively prompt for a password.\n- `\"string\"`: Use the provided password value.",
      "anyOf": [
        {
          "description": "Interactive prompt (`true`) or disabled (`false`).",
          "type": "boolean"
        },
        {
          "description": "A literal password value.",
          "type": "string"
        }
      ]
    },
    "SshConfig": {
      "type": "object",
      "properties": {
        "host": {
          "type": "string"
        },
        "key_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "password": {
          "description": "Password authentication: `false` (default), `true` (prompt), or a string value.",
          "$ref": "#/$defs/PasswordConfig"
        },
        "port": {
          "type": "integer",
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "user": {
          "type": "string"
        }
      },
      "required": [
        "host",
        "port",
        "user",
        "password"
      ]
    },
    "SyncConfig": {
      "type": "object",
      "properties": {
        "ignore_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "remote_root": {
          "type": "string"
        }
      },
      "required": [
        "remote_root",
        "ignore_files"
      ]
    }
  }
}
