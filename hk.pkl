amends "https://raw.githubusercontent.com/risu729/hk-config/v1.0.0/presets.pkl"

import "https://raw.githubusercontent.com/risu729/hk-config/v1.0.0/helpers.pkl"

local docsLint = helpers.pick(new Listing { "oxlint" })

local docs = new Group {
  dir = "docs"
  steps {
    ["oxlint"] = (docsLint["oxlint"]) {
      glob = List(".vitepress/**/*.ts", "**/*.js", "**/*.ts", "**/*.vue")
    }
    ["tsc"] = new Step {
      // VitePress: vue-tsc + tsc; not catalog Builtins.tsc (`tsc --noEmit -p …`)
      glob = List(".vitepress/**/*.ts", "**/*.ts", "**/*.vue", "tsconfig*.json")
      stomp = true
      check = "bun run vue-tsc && bun run tsc"
    }
  }
}

local picked =
  helpers.pick(new Listing {
    "rust"
    "github-actions"
    "oxfmt"
    "tombi"
    "yaml"
    "typos"
    "hygiene"
  })

hooks =
  helpers.standardHooks((picked) {
    ["oxfmt"] = (picked["oxfmt"]) {
      // Duplicate .oxfmtrc.json ignorePatterns so hk skips this step when only
      // ignored paths change; oxfmt ignore alone still runs the step and exits 0.
      exclude = List("CHANGELOG.md", "docs/src/cli/**", "schema/**", "**/*.toml")
    }
    ["typos"] = (picked["typos"]) {
      // Ignore autogenerated files.
      exclude = List(".gitignore", "biwa.usage.kdl", "CHANGELOG.md", "docs/src/cli/**")
    }
    ["docs"] = docs
  })
