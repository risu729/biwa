amends "https://raw.githubusercontent.com/risu729/hk-config/v1.0.2/presets.pkl"
import "https://raw.githubusercontent.com/risu729/hk-config/v1.0.2/helpers.pkl"

local docs = new Group {
  dir = "docs"
  steps {
    ["oxlint"] = new Step {
      glob = List(".vitepress/**/*.ts", "**/*.js", "**/*.ts", "**/*.vue")
      check =
        "oxlint --deny-warnings --report-unused-disable-directives-severity error {{ files }}"
      fix =
        "oxlint --deny-warnings --report-unused-disable-directives-severity error --fix {{ files }}"
    }
    ["tsc"] = new Step {
      glob = List(".vitepress/**/*.ts", "**/*.ts", "**/*.vue", "tsconfig*.json")
      stomp = true
      check = "bun run vue-tsc && bun run tsc"
    }
  }
}

local picked = helpers.pick(new Listing {
  "clippy"
  "rustfmt"
  "cargo-deny"
  "github-actions"
  "oxfmt"
  "tombi"
  "tombi-format"
  "yamllint"
  "typos"
})

hooks = helpers.standardHooks((picked) {
  ["oxfmt"] = (picked["oxfmt"]) {
    // Duplicate .oxfmtrc.json ignorePatterns so hk skips this step when only
    // ignored paths change; oxfmt ignore alone still runs the step and exits 0.
    exclude = List("CHANGELOG.md", "docs/src/cli/**", "schema/**", "**/*.toml")
  }
  ["typos"] = (picked["typos"]) {
    // Duplicate typos.toml extend-exclude for tracked paths matched by **/*.
    exclude = List(".gitignore", "biwa.usage.kdl", "CHANGELOG.md", "docs/src/cli/**")
  }
  ["docs"] = docs
})
