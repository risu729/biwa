amends "https://raw.githubusercontent.com/risu729/hk-config/v1.1.0/presets.pkl"

import "https://raw.githubusercontent.com/risu729/hk-config/v1.1.0/helpers.pkl"

subprojects = List("docs")

local picked =
  helpers.pick(new Listing {
    "rust"
    "github-actions"
    "oxfmt"
    "tombi"
    "yaml"
    "typos"
    "hygiene"
  })

hooks =
  helpers.standardHooks((picked) {
    ["hygiene"] = (picked["hygiene"] as Group) {
      steps = ((picked["hygiene"] as Group).steps) {
        ["newlines"] = ((picked["hygiene"] as Group).steps["newlines"]) {
          // release-plz generates CHANGELOG.md without a trailing newline.
          exclude = List("CHANGELOG.md")
        }
      }
    }
    ["oxfmt"] = (picked["oxfmt"]) {
      // Duplicate .oxfmtrc.json ignorePatterns so hk skips this step when only
      // ignored paths change; oxfmt ignore alone still runs the step and exits 0.
      exclude = List("CHANGELOG.md", "docs/src/cli/**", "schema/**", "**/*.toml")
    }
    ["typos"] = (picked["typos"]) {
      // Ignore autogenerated files.
      exclude = List(".gitignore", "biwa.usage.kdl", "CHANGELOG.md", "docs/src/cli/**")
    }
  })
