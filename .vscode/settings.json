{
	// ref: https://code.visualstudio.com/docs/getstarted/settings#_workspace-settings

	"[rust]": {
		"editor.defaultFormatter": "rust-lang.rust-analyzer"
	},
	"[typescript][javascript][css][vue][json][jsonc][yaml][github-actions-workflow][markdown]": {
		"editor.defaultFormatter": "oxc.oxc-vscode"
	},
	"[toml]": {
		"editor.defaultFormatter": "tombi-toml.tombi"
	},

	"files.readonlyInclude": {
		// auto-generated
		"**/Cargo.lock": true,
		"biwa.usage.kdl": true,
		"docs/src/cli/*": true,
		"schema/config.json": true
	}
}
